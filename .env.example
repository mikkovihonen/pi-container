# SECURITY: ADMIN_PASSWORD MUST be changed from CHANGEME before running.
# The proxy's mitmweb UI will refuse to start with this default value.
PI_IMAGE_TAG=pi-coding-agent:local
PROXY_IMAGE_TAG=pi-coding-agent-proxy:local
LLAMA_BIN=/opt/homebrew/bin/llama-server
LOG_LEVEL=INFO
ADMIN_PASSWORD=CHANGEME
# CONTAINER_RUNTIME=  # Optional: container, docker, or podman.
# Defaults to auto-detection (prefers container > docker > podman).

# Network settings are derived from the chosen runtime and rarely need
# overriding. Leave unset to use the per-runtime defaults:
#   container: bridge100 / default    podman: podman0 / podman    docker: docker0 / bridge
# Uncommenting these forces the value for ALL runtimes, so only set them if you
# know the interface/network name differs on your host.
# BRIDGE_INTERFACE=bridge100
# PROXY_UPSTREAM_NETWORK=default

# ── IPv6 support ────────────────────────────────────────────────────────────
# Whether the proxy/agent network stack supports IPv6. Default: false.
#   false  IPv6 is explicitly disabled across the board — the isolated network
#          is IPv4-only, both containers disable IPv6 via sysctl, and apt is
#          forced onto IPv4. This is the safe default: it prevents the agent
#          from silently egressing UNINSPECTED over IPv6 (mitmproxy's transparent
#          REDIRECT and the allowlist would otherwise be bypassed), and avoids
#          failures like apt picking an AAAA record with no v6 route.
#   true   The isolated network is created with an IPv6 subnet (--ipv6 for
#          podman/docker, --subnet-v6 for Apple `container`), the proxy mirrors
#          its v4 REDIRECT/NAT/FORWARD rules in ip6tables, and the agent gets an
#          IPv6 default route via the proxy. Requires the container runtime AND
#          host to actually have IPv6 egress. Apple `container`'s vmnet NATs
#          IPv4 only (no v6 egress — verified), so enabling this there logs a
#          warning and v6 connections still fail; it is intended for Linux hosts
#          running podman/docker with working host IPv6.
IPV6_ENABLED=false

# ── Proxy egress policy ─────────────────────────────────────────────────────
# The proxy egress policy is a PER-PROJECT setting, not an environment variable.
# Opt protocols in per workspace in .pi-container/egress.yaml (ssh/smtp/git/ntp
# flags + tcp_ports/udp_ports lists), seeded from
# pi-coding-agent/default/egress.yaml on first run.

# ── mitmweb flow export ─────────────────────────────────────────────────────
# Flow export is a PER-PROJECT setting, not an environment variable. Toggle it
# per workspace in .pi-container/flow_export.yaml (`enabled: true|false`),
# seeded from pi-coding-agent/default/flow_export.yaml on first run.